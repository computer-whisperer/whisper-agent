# whisper-agent-host-daemon runtime configuration.
#
# This file is read by the systemd unit (whisper-agent-host-daemon.service)
# as an EnvironmentFile and is marked as a config backup in the package
# manifest, so pacman will preserve local edits across upgrades.
#
# Both values below are REQUIRED — the unit will not start without them.

# WebSocket URL of the central whisper-agent server's host-env endpoint.
# Use `wss://` for production (TLS via the system root store); `ws://`
# is only safe for loopback dev. The daemon dials this URL with
# exponential-backoff retry, so it's fine to bring the daemon up before
# the server (or after a server restart).
WHISPER_AGENT_SERVER_URL=wss://CHANGE_ME.example.com/v1/host_env_link

# Path to the bearer token the daemon presents on the WS upgrade. The
# same token must be configured server-side as `[[auth.daemons]]
# token = "..."` with this host's chosen daemon name. Generate with
# e.g. `openssl rand -base64 32` and install at the path below mode
# 0600 (StateDirectory= on the unit makes /var/lib/whisper-agent
# readable only by root).
WHISPER_AGENT_TOKEN_FILE=/var/lib/whisper-agent/host-daemon-token
