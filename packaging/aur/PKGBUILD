# Maintainer: Christian Balcom <robot.inventor@gmail.com>
#
# Host-side daemons for whisper-agent. Bundles whisper-agent-host-daemon
# (the per-thread landlock provisioner that dials a central whisper-agent
# server over WebSocket) and whisper-agent-mcp-host (the per-thread MCP
# server it spawns). Run these on each managed POSIX host the central
# whisper-agent server should reach into.
#
# The server-side image (whisper-agent + shared MCP sidecars) ships as
# an OCI image built from the repository's top-level Dockerfile and
# is not part of this package.
#
# Bumping this for a new release:
#   1. Tag the upstream release: `git tag v0.x.y && git push --tags`
#   2. Update pkgver below; reset pkgrel to 1.
#   3. updpkgsums   (refreshes the source tarball checksum)
#   4. makepkg --syncdeps --clean   (verify it builds)
#   5. Push to AUR (separate `aur:whisper-agent-host` git remote).

pkgname=whisper-agent-host
pkgver=0.3.22
pkgrel=1
pkgdesc="Host-side daemon for whisper-agent (landlock-isolated per-thread MCP hosts; dials a central server)"
arch=('x86_64' 'aarch64')
url="https://github.com/computer-whisperer/whisper-agent"
license=('MIT' 'Apache')
depends=('glibc' 'gcc-libs' 'systemd')
makedepends=('rust' 'cargo')
provides=('whisper-agent-host-daemon' 'whisper-agent-mcp-host')
backup=('etc/whisper-agent/host-daemon.env')
install="${pkgname}.install"
# `ring`'s hand-written assembly objects don't survive LTO link
# (rust-lld emits "undefined symbol: ring_core_*" for the asm-only
# entry points). Override the system makepkg.conf's `lto` default
# so cargo's release profile links the asm objects through normally.
options=('!lto')
source=(
    "${pkgname}-${pkgver}.tar.gz::${url}/archive/v${pkgver}.tar.gz"
    'host-daemon.env'
    'whisper-agent-host-daemon.service'
)
# Refresh with `updpkgsums` whenever pkgver bumps or either local file
# changes — the second two checksums pin the in-repo `host-daemon.env`
# and `whisper-agent-host-daemon.service`. `SKIP` would also be fine
# (those files are versioned upstream) but updpkgsums fills them in.
sha256sums=('000c64951de013427ce4025f01a3af0a157bb62aa1ddca62b1be7911a2027f1e'
            '956f642a3524ddbfe00c729fd4aee07d1c422e1a423606786276f886a259dc7f'
            'b461d5d9b82bbb36e6c3fae00783dc1a71de64de1eaf1a143bf70146e855b266')

prepare() {
    cd "${srcdir}/whisper-agent-${pkgver}"
    cargo fetch --locked --target "$(rustc -vV | sed -n 's/host: //p')"
}

build() {
    cd "${srcdir}/whisper-agent-${pkgver}"
    export CARGO_TARGET_DIR="${srcdir}/target"
    export RUSTUP_TOOLCHAIN=stable
    # Only the two host-side bins; the rest of the workspace (server,
    # webui, shared MCP daemons) is not packaged here.
    cargo build --release --frozen \
        -p whisper-agent-host-daemon \
        -p whisper-agent-mcp-host
}

check() {
    cd "${srcdir}/whisper-agent-${pkgver}"
    export CARGO_TARGET_DIR="${srcdir}/target"
    export RUSTUP_TOOLCHAIN=stable
    cargo test --release --frozen \
        -p whisper-agent-host-daemon \
        -p whisper-agent-mcp-host
}

package() {
    cd "${srcdir}/whisper-agent-${pkgver}"

    install -Dm755 "${srcdir}/target/release/whisper-agent-host-daemon" \
        "${pkgdir}/usr/bin/whisper-agent-host-daemon"
    install -Dm755 "${srcdir}/target/release/whisper-agent-mcp-host" \
        "${pkgdir}/usr/bin/whisper-agent-mcp-host"

    install -Dm644 "${srcdir}/whisper-agent-host-daemon.service" \
        "${pkgdir}/usr/lib/systemd/system/whisper-agent-host-daemon.service"

    install -Dm644 "${srcdir}/host-daemon.env" \
        "${pkgdir}/etc/whisper-agent/host-daemon.env"

    install -Dm644 LICENSE-MIT \
        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-MIT"
    install -Dm644 LICENSE-APACHE \
        "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE-APACHE"
    install -Dm644 README.md \
        "${pkgdir}/usr/share/doc/${pkgname}/README.md"
}
