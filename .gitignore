# Claude Code per-workspace state (developer-local)
.claude/

# Rust build artifacts (added ahead of any actual Rust code)
/target/
**/target/

# Local secrets — cloud API keys, sourced into env for development
CLOUD_KEYS.txt

# Server config: copied from whisper-agent.toml.example by users; holds API keys.
/whisper-agent.toml

# wasm-pack output (generated, served by the whisper-agent server)
crates/whisper-agent-webui/pkg/

# Runtime artifacts at the repo root (default paths for `whisper-agent serve` / `run`)
/audit.jsonl
/conversation.json
/tasks/

# Dev-script sandbox: mcp-host workspace + audit log + task JSON (see scripts/dev.sh)
/sandbox/

# Android client: captured logcat dumps (ad-hoc decode debugging)
/adb_log.txt

# makepkg outputs under packaging/aur/ (source tarball + built packages)
packaging/aur/*.pkg.tar.zst
packaging/aur/*.tar.gz

# Knowledge bucket runtime artifacts. The user's bucket.toml is the
# config we want to track; everything else under <bucket>/ is generated
# at build / index / download time and is per-deployment local.
/buckets/*/slots/
/buckets/*/source-cache/
/buckets/*/feed-state.toml
/buckets/*/*.partial
